{
	"name": "native",
	"main": "expo-router/entry",
	"version": "1.0.0",
	"scripts": {
		"start": "expo start",
		"eas-build-pre-install": "./scripts/eas-install-rust.sh",
		"web:desktop": "BROWSER=none expo start --web --port 8082",
		"all": "sh -c 'trap \"kill 0\" INT TERM EXIT; npm run desktop & npm run android:dev & wait'",
		"android": "npx expo prebuild --platform android --clean && ./scripts/build-mobile-git.sh android && cd android && ./gradlew :app:installRelease",
		"android:dev": "APP_VARIANT=development npx expo prebuild --platform android --clean && ./scripts/build-mobile-git.sh android && cd android && ./gradlew :app:installDebug && cd .. && (adb reverse tcp:8081 tcp:8081 || true) && npx expo start --dev-client",
		"desktop": "tauri dev",
		"ios": "expo run:ios",
		"build:web": "expo export --platform web",
		"build:mobile-git": "./scripts/build-mobile-git.sh",
		"desktop:devtools": "sh -c 'trap \"kill 0\" INT TERM EXIT; react-devtools & npm run desktop & wait'",
		"build:desktop": "tauri build",
		"migrate:note-metadata": "node ./scripts/update-note-metadata.mjs",
		"test": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
		"test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
		"lint": "biome lint .",
		"lint:fix": "biome check . --apply",
		"knip": "knip"
	},
	"dependencies": {
		"@expo/vector-icons": "^15.0.3",
		"@react-native-async-storage/async-storage": "^2.2.0",
		"@react-navigation/native": "^7.1.8",
		"expo": "~54.0.33",
		"expo-clipboard": "~8.0.3",
		"expo-constants": "~18.0.13",
		"expo-dev-client": "~6.0.20",
		"expo-document-picker": "~14.0.8",
		"expo-file-system": "~19.0.21",
		"expo-font": "~14.0.11",
		"expo-image": "~3.0.11",
		"expo-linking": "~8.0.11",
		"expo-modules-core": "~3.0.29",
		"expo-router": "~6.0.23",
		"expo-splash-screen": "~31.0.13",
		"expo-sqlite": "~16.0.10",
		"expo-system-ui": "~6.0.9",
		"expo-updates": "~29.0.16",
		"katex": "^0.16.11",
		"nanoid": "^5.1.6",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"react-native": "0.81.5",
		"react-native-gesture-handler": "~2.28.0",
		"react-native-get-random-values": "^2.0.0",
		"react-native-mathjax-html-to-svg": "^1.1.0",
		"react-native-safe-area-context": "~5.6.0",
		"react-native-screens": "~4.16.0",
		"react-native-svg": "15.15.3",
		"react-native-web": "~0.21.0",
		"react-native-webview": "13.15.0",
		"react-syntax-highlighter": "^16.1.0",
		"zustand": "^5.0.10"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@jest/globals": "^29.7.0",
		"@tauri-apps/cli": "^2.10.0",
		"@testing-library/react-native": "^13.3.3",
		"@types/jest": "^29.5.14",
		"@types/katex": "^0.16.8",
		"@types/node": "^25.4.0",
		"@types/react": "~19.1.0",
		"@types/react-syntax-highlighter": "^15.5.13",
		"@welldone-software/why-did-you-render": "^10.0.1",
		"babel-plugin-dynamic-import-node": "^2.3.3",
		"jest": "^29.7.0",
		"jest-expo": "^55.0.10",
		"jsdom": "^20.0.3",
		"knip": "^5.86.0",
		"react-test-renderer": "^19.1.0",
		"typescript": "~5.9.2"
	},
	"private": true
}
