{
	"name": "native",
	"main": "expo-router/entry",
	"version": "1.0.0",
	"scripts": {
		"start": "expo start",
		"web:desktop": "BROWSER=none expo start --web --port 8082",
		"build:web": "expo export --platform web",
		"android": "npx expo prebuild --platform android --clean && ./scripts/build-mobile-git.sh android && cd android && ./gradlew :app:installRelease",
		"android:dev": "APP_VARIANT=development npx expo prebuild --platform android --clean && ./scripts/build-mobile-git.sh android && cd android && ./gradlew :app:installDebug && cd .. && (adb reverse tcp:8082 tcp:8082 || true) && npx expo start --dev-client",
		"ios": "expo run:ios",
		"build:mobile-git": "./scripts/build-mobile-git.sh",
		"desktop": "tauri dev",
		"build:desktop": "tauri build",
		"lint": "biome lint .",
		"lint:fix": "biome check . --apply",
		"knip": "knip"
	},
	"dependencies": {
		"@expo/vector-icons": "^15.0.3",
		"@react-native-async-storage/async-storage": "^2.2.0",
		"@react-navigation/native": "^7.1.8",
		"expo": "~54.0.33",
		"expo-clipboard": "~8.0.3",
		"expo-constants": "~18.0.13",
		"expo-dev-client": "~6.0.20",
		"expo-document-picker": "~14.0.8",
		"expo-file-system": "~19.0.21",
		"expo-font": "~14.0.11",
		"expo-image": "~3.0.11",
		"expo-linking": "~8.0.11",
		"expo-router": "~6.0.23",
		"expo-splash-screen": "~31.0.13",
		"expo-sqlite": "~16.0.10",
		"expo-system-ui": "~6.0.9",
		"expo-updates": "~29.0.16",
		"highlight.js": "^11.10.0",
		"katex": "^0.16.11",
		"nanoid": "^5.1.6",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"react-native": "0.81.5",
		"react-native-gesture-handler": "~2.28.0",
		"react-native-get-random-values": "^2.0.0",
		"react-native-mathjax-html-to-svg": "^1.1.0",
		"react-native-screens": "~4.16.0",
		"react-native-svg": "15.15.3",
		"react-native-web": "~0.21.0",
		"react-native-webview": "13.15.0",
		"react-syntax-highlighter": "^16.1.0",
		"zustand": "^5.0.10"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@tauri-apps/cli": "^2.10.0",
		"@types/katex": "^0.16.8",
		"@types/node": "^25.4.0",
		"@types/react": "~19.1.0",
		"@types/react-syntax-highlighter": "^15.5.13",
		"@welldone-software/why-did-you-render": "^10.0.1",
		"knip": "^5.86.0",
		"typescript": "~5.9.2"
	},
	"private": true
}
