{
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
	"productName": "Keeper",
	"version": "0.1.0",
	"identifier": "com.clikethis123.keeper",
	"build": {
		"frontendDist": "../dist",
		"devUrl": "http://localhost:8082",
		"beforeDevCommand": "lsof -ti:8082 > /dev/null 2>&1 || npm run web:desktop",
		"beforeBuildCommand": "npm run build:web"
	},
	"app": {
		"windows": [
			{
				"title": "Keeper",
				"width": 800,
				"height": 600,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"macOS": {
			"dmg": {
				"windowSize": {
					"width": 660,
					"height": 400
				},
				"appPosition": {
					"x": 180,
					"y": 170
				},
				"applicationFolderPosition": {
					"x": 480,
					"y": 170
				}
			}
		}
	}
}
