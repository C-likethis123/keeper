{
	"$schema": "https://biomejs.dev/schemas/2.3.11/schema.json",
	"files": {
		"ignore": [
			"dist",
			"node_modules",
			".expo",
			"src-tauri",
			"ios/Pods",
			"ios/build",
			"android/build",
			"android/app/build",
			".claude/skills"
		]
	},
	"formatter": {
		"enabled": true
	},
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	}
}
