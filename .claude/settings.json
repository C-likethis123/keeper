{
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(mkdir:*)",
      "Bash(npm run:*)",
      "Bash(npx biome:*)",
      "Bash(npx jest:*)",
      "Bash(npm test:*)",
      "Bash(git add:*)",
      "Bash(git status:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git branch:*)",
      "Bash(git diff:*)",
      "Edit(/src/**)",
      "Edit(docs/**)",
      "mcp__ide__getDiagnostics",
      "Bash(npx expo:*)",
      "Bash(npx tsc *)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ],
    "deny": [
      "Bash(npm install:*)",
      "Bash(npm uninstall:*)",
      "Bash(pip install:*)",
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(sudo:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(brew:*)",
      "Bash(docker:*)",
      "Bash(kubectl:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/keeper/scripts/remind-update-docs.sh"
          }
        ]
      }
    ]
  }
}
